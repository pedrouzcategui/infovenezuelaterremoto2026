# --- Supabase ---
# From your Supabase project: Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Settings > API > service_role (SECRET — server only, never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Admin access (no user accounts; just you) ---
# The password you type on /admin/login
ADMIN_PASSWORD=change-me-to-something-strong
# A long random string used to sign the admin session cookie.
# Generate one with:  openssl rand -hex 32
ADMIN_SESSION_SECRET=replace-with-openssl-rand-hex-32

# --- SEO / sharing ---
# Your public site URL (used for canonical links, sitemap, Open Graph).
# In Vercel set this to your real domain, e.g. https://centrosdeacopio.org
NEXT_PUBLIC_SITE_URL=https://infovenezuelaterremoto.org

# --- Google Analytics (optional) ---
# Create a GA4 property at analytics.google.com -> Admin -> Data Streams -> Web,
# then paste the Measurement ID here (starts with "G-"). Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# --- Admin login by email code (OTP, optional but recommended) ---
# If RESEND_API_KEY is set, /admin/login switches to emailing a 6-digit code to
# ADMIN_EMAIL (only you receive it). If blank, it falls back to the password above.
# Get the key at resend.com -> API Keys.
RESEND_API_KEY=
ADMIN_EMAIL=pedro@pedrouzcategui.com
# Sender. Use onboarding@resend.dev for testing, or a verified domain in production.
EMAIL_FROM=Info Venezuela Terremoto <onboarding@resend.dev>
